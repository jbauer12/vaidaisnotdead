{{!< default}}

<div class="container">
    <div class="tag-header">
        <p class="section-kicker">FAQ</p>
        <h1 class="tag-title">{{@custom.faq_title}}</h1>
    </div>

    <div class="faq-list">
        {{#if posts}}
            {{#foreach posts}}
                <details class="faq-item">
                    <summary class="faq-question">{{title}}</summary>
                    <div class="faq-answer">
                        {{content}}
                    </div>
                </details>
            {{/foreach}}
        {{else}}
            <div class="empty-state">
                <strong>Noch keine FAQ-Einträge vorhanden.</strong>
                <p>Erstelle Beiträge mit dem Tag <code>faq</code> — Titel = Frage, Inhalt = Antwort.</p>
            </div>
        {{/if}}
    </div>
</div>
