{{!< default}}

<article class="{{post_class}}">
    <div class="post-header container">
        {{#if primary_tag}}
            <p class="hero-kicker">{{primary_tag.name}}</p>
        {{/if}}
        <h1 class="post-title">{{title}}</h1>
        <p class="post-meta">
            {{date published_at format="D. MMMM YYYY"}}
            {{#if primary_author}} · {{primary_author.name}}{{/if}}
        </p>
    </div>

    {{#if feature_image}}
    <div class="container">
        <img class="post-feature-image"
             src="{{img_url feature_image size="l"}}"
             srcset="{{img_url feature_image size="m"}} 600w, {{img_url feature_image size="l"}} 1000w, {{img_url feature_image size="xl"}} 2000w"
             sizes="(max-width: 768px) 100vw, 74rem"
             alt="{{title}}"
             loading="lazy">
    </div>
    {{/if}}

    <div class="container">
        <div class="post-content">
            {{content}}
            {{#if tags}}
            <div class="post-tags">
                {{#foreach tags}}
                    <span class="tag-pill">{{name}}</span>
                {{/foreach}}
            </div>
            {{/if}}
        </div>
    </div>
</article>
