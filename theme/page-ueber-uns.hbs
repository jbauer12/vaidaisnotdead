{{!< default}}

<div class="container">
    <div class="page-header">
        <p class="section-kicker">Über Uns</p>
        <h1 class="page-title">{{@custom.ueber_uns_page_title}}</h1>
        <p class="page-desc">{{@custom.ueber_uns_page_desc}}</p>
    </div>

    {{#if content}}
    <div class="page-content">
        {{content}}
    </div>
    {{/if}}

    <section class="mitglieder-section">
        <div class="mitglieder-header">
            <p class="section-kicker">{{@custom.mitglieder_kicker}}</p>
            <h2 class="mitglieder-title">{{@custom.mitglieder_title}}</h2>
        </div>
        {{#get "posts" filter="tag:mitglied" limit="50" order="published_at asc"}}
        {{#if posts}}
        <div class="mitglieder-grid">
            {{#foreach posts}}
            <div class="mitglied-card">
                <div class="mitglied-img">
                    {{#if feature_image}}
                    <img src="{{img_url feature_image size='s'}}" alt="{{title}}">
                    {{/if}}
                </div>
                <div class="mitglied-info">
                    <p class="mitglied-name">{{title}}</p>
                    {{#if custom_excerpt}}
                    <p class="mitglied-role">{{custom_excerpt}}</p>
                    {{/if}}
                </div>
            </div>
            {{/foreach}}
        </div>
        {{else}}
        <p class="mitglieder-empty">{{@custom.mitglieder_empty}}</p>
        {{/if}}
        {{/get}}
    </section>
</div>
