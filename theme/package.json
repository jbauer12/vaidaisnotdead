{
    "name": "vaida",
    "description": "Theme for Vaida is not dead e.V.",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": ["ghost-theme"],
    "author": {
        "name": "Jonas",
        "email": "jonasbauerwi@gmail.com"
    },
    "config": {
        "posts_per_page": 25,
        "card_assets": true,
