                "type": "text",
                "default": "Fördermitglied werden.",
                "group": "Mitglied werden"
            },
            "mitglied_description": {
                "type": "text",
                "default": "Als Fördermitglied unterstützt du Vaida is not dead mit einem monatlichen Beitrag. Du hilfst dabei, Räume, Technik und Abende möglich zu machen – und kannst dich einbringen, so viel oder wenig du willst.",
                "group": "Mitglied werden"
            },
            "foerder_lead": {
                "type": "text",
                "default": "Du trägst den Verein finanziell und schaffst damit die Basis für alles, was wir machen. Ob du bei Abenden und Organisation dabei bist oder nur im Hintergrund unterstützt – beides ist wertvoll.",
                "group": "Mitglied werden"
            },
            "foerder_note": {
                "type": "text",
                "default": "Dein Beitrag macht möglich, was sonst nicht stattfinden würde.",
                "group": "Mitglied werden"
            },
            "instagram_url": {
                "type": "text",
                "default": "https://www.instagram.com/vaidaisnotdead_ev/",
                "group": "Kontakt"
            }
