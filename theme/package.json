                "type": "text",
                "default": "Motive, Flyer und erste öffentliche Eindrücke.",
                "group": "Galerie"
            },
            "galerie_description": {
                "type": "text",
                "default": "Fotos, Artwork und Eindrücke vergangener Abende.",
                "group": "Galerie"
            },
            "faq_title": {
                "type": "text",
                "default": "Häufig gestellte Fragen",
                "group": "FAQ"
            },
